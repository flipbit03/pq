#!/usr/bin/env python3
"""Bump version, update pyproject.toml, commit, and tag."""

import re
import subprocess
import sys
from pathlib import Path

PYPROJECT = Path(__file__).parent.parent / "pyproject.toml"
INIT_PY = Path(__file__).parent.parent / "src" / "pq" / "__init__.py"
SEMVER_PATTERN = re.compile(r"^(\d+)\.(\d+)\.(\d+)$")
BUMP_TYPES = {"patch", "minor", "major"}


def parse_version(version: str) -> tuple[int, int, int]:
    """Parse and validate semver string, returns (major, minor, patch)."""
    match = SEMVER_PATTERN.match(version)
    if not match:
        raise ValueError(f"Invalid semver: {version!r} (expected X.Y.Z)")
    return int(match.group(1)), int(match.group(2)), int(match.group(3))


def increment_version(current: tuple[int, int, int], bump_type: str) -> str:
    """Increment version based on bump type."""
    major, minor, patch = current
    if bump_type == "patch":
        return f"{major}.{minor}.{patch + 1}"
    elif bump_type == "minor":
        return f"{major}.{minor + 1}.0"
    else:  # major
        return f"{major + 1}.0.0"


def get_current_version() -> str:
    """Read current version from pyproject.toml."""
    content = PYPROJECT.read_text()
    match = re.search(r'^version\s*=\s*"([^"]+)"', content, re.MULTILINE)
    if not match:
        raise RuntimeError("Could not find version in pyproject.toml")
    return match.group(1)


def set_version(new_version: str) -> None:
    """Update version in pyproject.toml and src/pq/__init__.py."""
    content = PYPROJECT.read_text()
    new_content = re.sub(
        r'^(version\s*=\s*)"[^"]+"',
        f'\\1"{new_version}"',
        content,
        count=1,
        flags=re.MULTILINE,
    )
    PYPROJECT.write_text(new_content)

    init_content = INIT_PY.read_text()
    new_init_content = re.sub(
        r'^(__version__\s*=\s*)"[^"]+"',
        f'\\1"{new_version}"',
        init_content,
        count=1,
        flags=re.MULTILINE,
    )
    INIT_PY.write_text(new_init_content)


def run(cmd: list[str], check: bool = True) -> subprocess.CompletedProcess[str]:
    """Run a command and return the result."""
    return subprocess.run(cmd, check=check, capture_output=True, text=True)


def main() -> int:
    if len(sys.argv) < 2:
        print(
            f"Usage: {sys.argv[0]} <patch|minor|major|X.Y.Z> [--push] [--force]",
            file=sys.stderr,
        )
        print("Examples:", file=sys.stderr)
        print(f"  {sys.argv[0]} patch        # 0.2.2 -> 0.2.3", file=sys.stderr)
        print(f"  {sys.argv[0]} minor        # 0.2.2 -> 0.3.0", file=sys.stderr)
        print(f"  {sys.argv[0]} major        # 0.2.2 -> 1.0.0", file=sys.stderr)
        print(f"  {sys.argv[0]} 1.0.0        # explicit version", file=sys.stderr)
        return 1

    version_arg = sys.argv[1]
    push = "--push" in sys.argv
    force = "--force" in sys.argv

    # Get current version first (needed for both bump types and validation)
    try:
        current_version = get_current_version()
        current_tuple = parse_version(current_version)
    except (RuntimeError, ValueError) as e:
        print(f"Error reading current version: {e}", file=sys.stderr)
        return 1

    # Determine new version
    if version_arg in BUMP_TYPES:
        new_version = increment_version(current_tuple, version_arg)
        new_tuple = parse_version(new_version)
    else:
        new_version = version_arg
        try:
            new_tuple = parse_version(new_version)
        except ValueError as e:
            print(f"Error: {e}", file=sys.stderr)
            return 1

    # Ensure new version is higher (unless --force)
    if new_tuple <= current_tuple and not force:
        print(
            f"Error: New version {new_version} must be higher than current {current_version}",
            file=sys.stderr,
        )
        return 1

    # Update pyproject.toml
    set_version(new_version)
    print(f"Updated version: {current_version} -> {new_version}")

    # Commit (skip if no changes, e.g. same version with --force)
    run(["git", "add", str(PYPROJECT), str(INIT_PY)])
    diff = run(["git", "diff", "--cached", "--quiet"], check=False)
    if diff.returncode != 0:
        run(["git", "commit", "-m", f"Release {new_version}"])
        print(f"Committed: Release {new_version}")
    else:
        print("No changes to commit")

    # Tag with annotation (force if requested)
    tag_msg = f"Release {new_version}"
    if force:
        tag_cmd = ["git", "tag", "-a", "-f", new_version, "-m", tag_msg]
    else:
        tag_cmd = ["git", "tag", "-a", new_version, "-m", tag_msg]
    run(tag_cmd)
    print(f"Tagged: {new_version}")

    # Push if requested
    if push:
        run(["git", "push"])
        push_tags_cmd = (
            ["git", "push", "--tags", "--force"] if force else ["git", "push", "--tags"]
        )
        run(push_tags_cmd)
        print("Pushed to remote (CI will create GitHub release and publish to PyPI)")

    return 0


if __name__ == "__main__":
    sys.exit(main())
